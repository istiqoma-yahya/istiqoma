/* Malay usage descriptions — copy to ios/App/App/ms.lproj/InfoPlist.strings */

NSMicrophoneUsageDescription = "Istiqoma menggunakan mikrofon untuk merakam bacaan Al-Quran semasa latihan hafazan. Rakaman disimpan pada peranti anda atau dimuat naik ke akaun untuk penjejakan kemajuan.";

NSLocationWhenInUseUsageDescription = "Istiqoma menggunakan lokasi anda untuk mengira waktu solat yang tepat (Subuh, Zohor, Asar, Maghrib, Isyak) dan menunjukkan arah kiblat. Lokasi anda tidak disimpan secara kekal.";

NSLocationAlwaysAndWhenInUseUsageDescription = "Istiqoma menggunakan lokasi latar belakang untuk menghantar peringatan solat yang tepat walaupun aplikasi ditutup.";
