/* English usage descriptions — copy to ios/App/App/en.lproj/InfoPlist.strings */

NSMicrophoneUsageDescription = "Istiqoma uses the microphone to record Qur'an recitations for memorization practice. Recordings are kept on your device or saved to your account for progress tracking.";

NSLocationWhenInUseUsageDescription = "Istiqoma uses your location to calculate accurate prayer times (Fajr, Dhuhr, Asr, Maghrib, Isha) and show you the Qibla direction. Your location is never stored permanently.";

NSLocationAlwaysAndWhenInUseUsageDescription = "Istiqoma uses your background location to send accurate Sholat reminders even when the app is closed.";
